list-keys : ## List GnuPG keys
	gpg --list-keys
.PHONY : list-keys

delete-key : ## Delete GnuPG key `${FINGERPRINT}`
	gpg \
		--pinentry-mode loopback \
		--batch \
		--yes \
		--delete-secret-keys ${FINGERPRINT}
	gpg \
		--pinentry-mode loopback \
		--batch \
		--yes \
		--delete-key ${FINGERPRINT}
.PHONY : delete-key
