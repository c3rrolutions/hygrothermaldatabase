  </ItemGroup>

  <PropertyGroup>
    <EnableDefaultItems>false</EnableDefaultItems>
    <!-- '%5C' is the hexcode of the backslash '\' -->
    <MyExcludes>**/obj/**;**/bin/**;**/obj%5CDebug/**;**/bin%5CDebug/**;**/logs/**;**/files/**</MyExcludes>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="@(Compile)" />
    <Compile Include="**/*.cs" Exclude="$(MyExcludes)" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="@(Content)" />
    <Content Include="**/*.cshtml" Exclude="$(MyExcludes)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="**/*.graphql" Exclude="$(MyExcludes)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="**/*.json" Exclude="$(MyExcludes)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- <ItemGroup> -->
    <!-- List watched files with `dotnet watch - -list` -->
    <!-- By default, `dotnet watch` automatically tracks all files marked as Compile or Content. -->
    <!-- <Watch Include="**/*.ts" Exclude="$(MyExcludes)" /> -->
  <!-- </ItemGroup> -->
</Project>
